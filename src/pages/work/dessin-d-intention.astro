---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import { getWorkPage } from "../../data/work";

const page = getWorkPage("dessin-d-intention");
---

<ProjectLayout
  title={page.title}
  heroImage={page.heroImage}
  heroRatio={page.heroRatio}
  heroTone={page.heroTone}
  projectSections={page.sections}
  description={page.description}
/>
