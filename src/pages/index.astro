---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  { id: "graphique", label: "design graphique", num: "01" },
  { id: "workshop", label: "workshop", num: "02" },
  { id: "croquis", label: "croquis d'extérieur", num: "03" },
  { id: "whiteout", label: "whiteout", num: "" },
  { id: "typo", label: "typographie & mise en page", num: "04" },
  { id: "mv1", label: "modèle vivant", num: "05" },
  { id: "mv2", label: "modèle vivant", num: "06" },
  { id: "perspective", label: "perspective", num: "07" },
];

const timeline = [
  { year: "2026", desc: "Projet de fin d'année" },
  { year: "2025", desc: "Workshop & typographie" },
  { year: "2024", desc: "Croquis & perspective" },
  { year: "2023", desc: "Début des études" },
];
---

<BaseLayout title="Clément Jorge — design graphique">
  <!-- ===================== HERO ===================== -->
  <section class="hero" id="about">
    <h1 class="hero-title">
      <span class="hero-name">Clément&nbsp;Jorge&nbsp;&mdash;</span>
      <span class="hero-discipline">design<br />graphique</span>
    </h1>

    <p class="hero-intro">
      Actuellement étudiant en design graphique,<br />
      j'apprécie particulièrement la typographie,<br />
      l'édition et la mise en page.
    </p>
  </section>

  <!-- ===================== COMPOSITION ===================== -->
  <section class="composition" aria-label="Sélection de projets">
    {
      projects.map((p) => (
        <article class={`block block--${p.id}`}>
          <div class="placeholder">
            {p.id === "whiteout" && <span class="placeholder-tag">WHITEOUT</span>}
          </div>
          {p.id !== "whiteout" && (
            <span class="label">
              <span class="label-text">{p.label}</span>
              {p.num && <sup>{p.num}</sup>}
            </span>
          )}
        </article>
      ))
    }
  </section>

  <!-- ===================== ABOUT / QUOTE ===================== -->
  <section class="about">
    <div class="about-top">
      <blockquote class="about-quote">
        &ldquo;Petite phrase d'accroche,<br />
        Lorem ipsum dolor sit amet, consectetur<br />
        adipiscing elit, sed do eiusmod.&rdquo;
      </blockquote>
      <p class="about-byline">
        &mdash;&nbsp;Clément Jorge, étudiant en design graphique
      </p>
    </div>

    <div class="about-grid">
      <aside class="about-years" aria-label="Parcours">
        <dl>
          {
            timeline.map((t) => (
              <div class="about-year">
                <dt>{t.year}</dt>
                <dd>{t.desc}</dd>
              </div>
            ))
          }
        </dl>
      </aside>

      <figure class="about-media">
        <div class="about-img"></div>
        <figcaption>portrait &mdash; atelier, 2025</figcaption>
      </figure>

      <div class="about-body">
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim
          ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut
          aliquip ex ea commodo consequat.
        </p>
        <p>
          Duis aute irure dolor in reprehenderit in voluptate velit esse
          cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat
          cupidatat non proident, sunt in culpa qui officia deserunt mollit
          anim id est laborum.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ==========================================================
     HERO — deux masses typographiques en dialogue
     ========================================================== */
  .hero {
    padding: 4.5rem var(--pad-x) 0;
    position: relative;
  }

  .hero-title {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: end;
    column-gap: 2rem;
    font-size: clamp(2.75rem, 6vw, 6.75rem);
    line-height: 0.84;
    font-weight: 700;
    letter-spacing: -0.04em;
    margin: 0 0 2.25rem;
  }

  .hero-name {
    color: var(--noir);
    white-space: nowrap;
    grid-column: 1;
  }

  .hero-discipline {
    color: var(--orange);
    grid-column: 2;
    justify-self: end;
    text-align: left;
  }

  .hero-intro {
    max-width: 26rem;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--noir);
    margin: 0;
  }

  /* ==========================================================
     COMPOSITION — grille 16×12, ratios extrêmes
     ========================================================== */
  .composition {
    display: grid;
    grid-template-columns: repeat(16, 1fr);
    grid-template-rows: repeat(12, 1fr);
    column-gap: 1.4rem;
    row-gap: 1.4rem;
    padding: 5rem var(--pad-x) 8rem;
    min-height: 1020px;
  }

  .block {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    min-width: 0;
    min-height: 0;
  }

  .placeholder {
    flex: 1;
    background: var(--bleu);
    position: relative;
    overflow: hidden;
    min-height: 0;
  }

  .placeholder-tag {
    position: absolute;
    bottom: 0.9rem;
    right: 1rem;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--noir);
    text-transform: uppercase;
  }

  /* labels éditoriaux : plus présents, type caption de catalogue */
  .label {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: 0;
    color: var(--noir);
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .label-text {
    display: inline-block;
  }

  .label sup {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.06em;
    vertical-align: super;
    opacity: 0.7;
  }

  /* ---- placements asymétriques (16 cols × 12 rows) ---- */
  .block--graphique   { grid-column: 1 / 5;    grid-row: 2 / 10; }  /* 4×8 portrait */
  .block--workshop    { grid-column: 6 / 9;    grid-row: 1 / 4;  }  /* 3×3 carré */
  .block--croquis     { grid-column: 6 / 8;    grid-row: 5 / 7;  }  /* 2×2 petit */
  .block--whiteout    { grid-column: 9 / 14;   grid-row: 2 / 9;  }  /* 5×7 dominant */
  .block--typo        { grid-column: 15 / 17;  grid-row: 1 / 8;  }  /* 2×7 narrow tall */
  .block--mv1         { grid-column: 1 / 6;    grid-row: 10 / 13;}  /* 5×3 large paysage */
  .block--mv2         { grid-column: 8 / 9;    grid-row: 10 / 12;}  /* 1×2 miniature */
  .block--perspective { grid-column: 11 / 17;  grid-row: 9 / 13; }  /* 6×4 paysage */

  /* ==========================================================
     ABOUT — double-page éditoriale
     ========================================================== */
  .about {
    background: var(--sauge);
    padding: 7rem var(--pad-x) 9rem;
    color: var(--noir);
  }

  /* --- haut : citation massive, alignée à droite --- */
  .about-top {
    padding-left: 32%;
    margin-bottom: 7rem;
  }

  .about-quote {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.15vw, 3.6rem);
    font-weight: 400;
    line-height: 1.06;
    letter-spacing: -0.02em;
    margin: 0 0 1.1rem;
  }

  .about-byline {
    font-family: var(--font-body);
    font-size: 12.5px;
    opacity: 0.65;
    margin: 0;
    letter-spacing: 0.01em;
  }

  /* --- bas : grille 3 colonnes type mise en page --- */
  .about-grid {
    display: grid;
    grid-template-columns: 0.85fr 1.1fr 1.6fr;
    column-gap: 3.5rem;
    row-gap: 2rem;
    align-items: start;
  }

  /* col 1 : timeline */
  .about-years dl {
    margin: 0;
    display: grid;
    gap: 1.35rem;
  }

  .about-year {
    display: grid;
    gap: 0.3rem;
  }

  .about-year dt {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .about-year dd {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    opacity: 0.7;
    max-width: 18ch;
  }

  /* col 2 : image + caption */
  .about-media {
    margin: 0;
  }

  .about-img {
    width: 100%;
    aspect-ratio: 4 / 5;
    background: var(--bleu);
  }

  .about-media figcaption {
    font-family: var(--font-body);
    font-size: 11px;
    opacity: 0.6;
    margin-top: 0.55rem;
    letter-spacing: 0.02em;
  }

  /* col 3 : texte */
  .about-body {
    display: grid;
    gap: 1rem;
    font-family: var(--font-body);
    font-size: 13.5px;
    line-height: 1.6;
    max-width: 36rem;
  }

  .about-body p {
    margin: 0;
  }

  /* ==========================================================
     RESPONSIVE BASIQUE (sécurité, pas prioritaire)
     ========================================================== */
  @media (max-width: 960px) {
    .hero-title {
      grid-template-columns: 1fr;
      align-items: start;
      row-gap: 0.5rem;
    }
    .hero-name { white-space: normal; }
    .hero-discipline {
      grid-column: 1;
      justify-self: start;
    }

    .composition {
      grid-template-columns: repeat(6, 1fr);
      grid-template-rows: auto;
      min-height: 0;
    }
    .block {
      grid-column: auto !important;
      grid-row: auto !important;
    }
    .block--graphique,
    .block--whiteout,
    .block--perspective { grid-column: span 6 !important; }
    .block--workshop,
    .block--croquis,
    .block--typo,
    .block--mv1,
    .block--mv2 { grid-column: span 3 !important; }
    .block .placeholder { aspect-ratio: 1; }

    .about-top { padding-left: 0; }
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
