---
---

<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Clément Jorge — Portfolio</title>
    <style>
      :root {
        font-family: Arial, Helvetica, sans-serif;
        color: #111;
        background: #f5f1ea;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
      }

      main {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
      }

      .intro {
        max-width: 900px;
        width: 100%;
      }

      h1 {
        font-size: clamp(3rem, 8vw, 7rem);
        line-height: 0.95;
        margin: 0 0 1rem 0;
        font-weight: 600;
      }

      p {
        font-size: 1.1rem;
        max-width: 36rem;
        line-height: 1.6;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <main>
      <section class="intro">
        <h1>Clément Jorge</h1>
        <p>
          Portfolio en construction — design graphique, direction visuelle et projets créatifs.
        </p>
      </section>
    </main>
  </body>
</html>