<div id="page-transition" aria-hidden="true">
  <span id="page-transition-count">00</span>
</div>

<script>
  (() => {
    const storageKey = "cj-page-transition";
    const progressKey = "cj-page-transition-progress";
    const outgoingProgressTarget = 34;
    const loadingProgressTarget = 96;
    const simulatedProgressTarget = 92;
    const overlay = document.getElementById("page-transition");
    const count = document.getElementById("page-transition-count");
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealEvent = "cj:page-transition-revealed";
    let currentCount = 0;

    if (!overlay || !count) return;

    try {
      window.__cjPageTransitionReady = sessionStorage.getItem(storageKey) !== "1";
    } catch (_) {
      window.__cjPageTransitionReady = true;
    }

    const markPageRevealed = () => {
      window.__cjPageTransitionReady = true;
      window.dispatchEvent(new CustomEvent(revealEvent));
    };

    const clampProgress = (value) => {
      const number = Number(value);
      if (!Number.isFinite(number)) return 0;
      return Math.max(0, Math.min(100, number));
    };

    const format = (value) => String(Math.round(clampProgress(value))).padStart(2, "0");

    const setCount = (value) => {
      currentCount = clampProgress(value);
      count.textContent = format(currentCount);
    };

    const nextFrame = () => new Promise((resolve) => requestAnimationFrame(resolve));

    const animateCount = (from, to, duration) => {
      if (reduced) {
        setCount(to);
        return Promise.resolve();
      }

      const start = performance.now();
      return new Promise((resolve) => {
        const tick = (now) => {
          const progress = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          setCount(from + (to - from) * eased);

          if (progress < 1) {
            requestAnimationFrame(tick);
          } else {
            resolve();
          }
        };

        requestAnimationFrame(tick);
      });
    };

    const imageIsReady = (image) => image.complete && image.naturalWidth > 0;

    const collectTransitionImages = () => {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight;

      return Array.from(document.images).filter((image) => {
        if (image.closest("#page-transition")) return false;
        if (!image.currentSrc && !image.src) return false;

        const rect = image.getBoundingClientRect();
        if (rect.width === 0 || rect.height === 0) return false;

        if (image.loading !== "lazy") return true;

        return rect.top < viewportHeight * 1.5 && rect.bottom > viewportHeight * -0.25;
      });
    };

    const waitForImage = (image) => {
      if (imageIsReady(image) || image.complete) return Promise.resolve();

      if (typeof image.decode === "function") {
        return image.decode().catch(() => undefined);
      }

      return new Promise((resolve) => {
        image.addEventListener("load", resolve, { once: true });
        image.addEventListener("error", resolve, { once: true });
      });
    };

    const animateToProgress = (target, duration) =>
      animateCount(currentCount, Math.max(currentCount, clampProgress(target)), duration);

    const waitForIncomingAssets = async (startProgress) => {
      await nextFrame();
      await nextFrame();

      const baseProgress = clampProgress(startProgress);
      setCount(baseProgress);

      const images = collectTransitionImages();
      const total = images.length;

      if (!total) {
        await animateToProgress(100, reduced ? 0 : 520);
        return;
      }

      let loaded = images.filter((image) => image.complete).length;
      const pendingImages = images.filter((image) => !image.complete);

      const progressForLoadedImages = () =>
        baseProgress + (Math.min(loaded, total) / total) * (loadingProgressTarget - baseProgress);

      if (!pendingImages.length) {
        await animateToProgress(progressForLoadedImages(), reduced ? 0 : 220);
        await animateToProgress(100, reduced ? 0 : 520);
        return;
      }

      let imageLoadingDone = false;
      const loadingStartedAt = performance.now();
      const timeout = new Promise((resolve) => window.setTimeout(resolve, 10000));
      const imageLoading = Promise.all(
        pendingImages.map((image) =>
          waitForImage(image).then(() => {
            loaded += 1;
          })
        )
      );
      const imageLoadingGate = Promise.race([imageLoading, timeout]).then(() => {
        imageLoadingDone = true;
      });

      await new Promise((resolve) => {
        const tick = (now) => {
          const elapsed = now - loadingStartedAt;
          const simulatedProgress =
            baseProgress +
            Math.min(elapsed / 4200, 1) * (simulatedProgressTarget - baseProgress);
          const target = Math.min(
            loadingProgressTarget,
            Math.max(progressForLoadedImages(), simulatedProgress)
          );
          const easing = imageLoadingDone ? 0.18 : 0.075;

          setCount(currentCount + (target - currentCount) * easing);

          if (!imageLoadingDone || elapsed < 560 || currentCount < Math.min(target, 99) - 0.7) {
            requestAnimationFrame(tick);
          } else {
            resolve();
          }
        };

        requestAnimationFrame(tick);
      });

      await imageLoadingGate;

      if (document.fonts?.ready) {
        await Promise.race([
          document.fonts.ready.catch(() => undefined),
          new Promise((resolve) => window.setTimeout(resolve, 500)),
        ]);
      }

      await animateToProgress(100, reduced ? 0 : 420);
    };

    const resetOverlay = () => {
      document.documentElement.classList.remove("has-page-transition-enter");
      overlay.classList.add("is-resetting");
      overlay.classList.remove("is-covering", "is-exiting");
      setCount(0);

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          overlay.classList.remove("is-resetting");
        });
      });
    };

    window.addEventListener("pageshow", (event) => {
      if (!event.persisted) return;

      try {
        sessionStorage.removeItem(storageKey);
        sessionStorage.removeItem(progressKey);
      } catch (_) {
        /* no-op */
      }

      resetOverlay();
      markPageRevealed();
    });

    const finishIncomingTransition = async () => {
      let shouldReveal = false;
      let incomingProgress = outgoingProgressTarget;

      try {
        shouldReveal = sessionStorage.getItem(storageKey) === "1";
        const storedProgress = Number(sessionStorage.getItem(progressKey));
        if (Number.isFinite(storedProgress)) {
          incomingProgress = clampProgress(storedProgress);
        }
        sessionStorage.removeItem(storageKey);
        sessionStorage.removeItem(progressKey);
      } catch (_) {
        shouldReveal = false;
      }

      if (!shouldReveal) {
        markPageRevealed();
        return;
      }

      window.__cjPageTransitionReady = false;

      setCount(incomingProgress);
      overlay.classList.add("is-covering");

      await waitForIncomingAssets(incomingProgress);
      await nextFrame();
      await nextFrame();
      document.documentElement.classList.remove("has-page-transition-enter");
      overlay.classList.add("is-exiting");

      window.setTimeout(markPageRevealed, reduced ? 0 : 560);
      window.setTimeout(() => {
        resetOverlay();
      }, reduced ? 0 : 850);
    };

    const isTransitionableLink = (link, event) => {
      if (!link || event.defaultPrevented) return false;
      if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return false;
      if (link.target && link.target !== "_self") return false;
      if (link.hasAttribute("download")) return false;

      const url = new URL(link.href, window.location.href);
      if (url.origin !== window.location.origin) return false;
      if (url.protocol !== "http:" && url.protocol !== "https:") return false;

      const currentPath = window.location.pathname.replace(/\/$/, "");
      const targetPath = url.pathname.replace(/\/$/, "");
      if (currentPath === targetPath && url.hash) return false;

      return url.href !== window.location.href;
    };

    document.addEventListener("click", async (event) => {
      const link = event.target.closest("a");
      if (!isTransitionableLink(link, event)) return;

      event.preventDefault();

      overlay.classList.remove("is-exiting");
      setCount(0);

      await new Promise((resolve) => requestAnimationFrame(resolve));
      overlay.classList.add("is-covering");
      await animateToProgress(outgoingProgressTarget, 560);

      try {
        sessionStorage.setItem(storageKey, "1");
        sessionStorage.setItem(progressKey, String(Math.round(currentCount)));
      } catch (_) {
        /* no-op */
      }

      window.location.href = link.href;
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", finishIncomingTransition, { once: true });
    } else {
      finishIncomingTransition();
    }
  })();
</script>

<style>
  #page-transition {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: grid;
    place-items: center;
    background: var(--orange);
    color: var(--noir);
    pointer-events: none;
    transform: translate3d(0, 100%, 0);
    transition: transform 780ms cubic-bezier(0.76, 0, 0.24, 1);
    will-change: transform;
  }

  #page-transition-count {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 13vw, 13rem);
    font-weight: 600;
    line-height: 0.8;
    letter-spacing: -0.06em;
    font-variant-numeric: tabular-nums;
  }

  html.has-page-transition-enter #page-transition,
  #page-transition.is-covering {
    transform: translate3d(0, 0, 0);
  }

  html.has-page-transition-enter #page-transition {
    transition: none;
  }

  #page-transition.is-exiting {
    transform: translate3d(0, -100%, 0);
    transition: transform 820ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  #page-transition.is-resetting {
    transform: translate3d(0, 100%, 0);
    transition: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #page-transition {
      transition: none;
    }
  }
</style>
