---
const { pathname } = Astro.url;
const isWork = pathname === "/work" || pathname === "/work/";
---

<header class="site-header">
  <nav aria-label="Navigation principale">
    <a href="/#about" class="interactive-zone">
      <span data-scramble-text="">About</span>
    </a>
    <a
      href="/work"
      class:list={["interactive-zone", { active: isWork }]}
    >
      <span data-scramble-text="">Work</span>
    </a>
    <a href="#contact" class="interactive-zone">
      <span data-scramble-text="">Contact</span>
    </a>
  </nav>
</header>

<script>
  (() => {
    const header = document.querySelector(".site-header");
    const links = Array.from(document.querySelectorAll(".site-header nav a"));
    if (!header || links.length === 0) return;

    const parseColor = (value) => {
      const color = value.trim();
      const rgb = color.match(/^rgba?\(([^)]+)\)$/i);

      if (rgb) {
        const parts = rgb[1].split(",").map((part) => Number.parseFloat(part.trim()));
        return {
          r: parts[0] || 0,
          g: parts[1] || 0,
          b: parts[2] || 0,
          a: parts.length > 3 ? parts[3] : 1,
        };
      }

      const hex = color.match(/^#([0-9a-f]{3}|[0-9a-f]{6})$/i);
      if (!hex) return null;

      const raw = hex[1].length === 3
        ? hex[1].split("").map((char) => char + char).join("")
        : hex[1];

      return {
        r: Number.parseInt(raw.slice(0, 2), 16),
        g: Number.parseInt(raw.slice(2, 4), 16),
        b: Number.parseInt(raw.slice(4, 6), 16),
        a: 1,
      };
    };

    const getSauge = () => parseColor(getComputedStyle(document.documentElement).getPropertyValue("--sauge"));

    const distance = (a, b) => {
      if (!a || !b) return Number.POSITIVE_INFINITY;
      return Math.hypot(a.r - b.r, a.g - b.g, a.b - b.b);
    };

    const visibleBackground = (element) => {
      let node = element;

      while (node && node instanceof Element) {
        const color = parseColor(getComputedStyle(node).backgroundColor);
        if (color && color.a > 0.01) return color;
        node = node.parentElement;
      }

      return parseColor(getComputedStyle(document.body).backgroundColor);
    };

    const isImageSurface = (element) => Boolean(element.closest(
      ".media-block-image, .media-placeholder, .project-image, .about-img, .project-hero-media, .gallery-media, .work-preview",
    ));

    const isGreenSurfaceAt = (x, y, sauge) => {
      const surface = document.elementsFromPoint(x, y).find((element) => !header.contains(element));
      const color = surface ? visibleBackground(surface) : null;

      return Boolean(surface) && !isImageSurface(surface) && distance(color, sauge) < 12;
    };

    const buildTextGradient = (text, sauge) => {
      const rect = text.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return "var(--orange)";

      const sampleCount = Math.max(10, Math.ceil(rect.height));
      const x = rect.left + rect.width / 2;
      const segments = [];
      let currentTone = null;
      let start = 0;

      for (let index = 0; index <= sampleCount; index += 1) {
        const progress = index / sampleCount;
        const y = rect.top + rect.height * progress;
        const tone = isGreenSurfaceAt(x, y, sauge) ? "var(--beige)" : "var(--orange)";

        if (currentTone === null) {
          currentTone = tone;
          start = 0;
          continue;
        }

        if (tone !== currentTone || index === sampleCount) {
          const end = progress * 100;
          segments.push(`${currentTone} ${start.toFixed(2)}%`, `${currentTone} ${end.toFixed(2)}%`);
          currentTone = tone;
          start = end;
        }
      }

      return `linear-gradient(to bottom, ${segments.join(", ")})`;
    };

    const updateLinkTone = () => {
      const sauge = getSauge();

      links.forEach((link) => {
        const text = link.querySelector("[data-scramble-text]");
        if (!text) return;

        const rect = text.getBoundingClientRect();
        const underlineY = rect.bottom + 1;
        const underlineX = rect.left + rect.width / 2;
        const underlineColor = isGreenSurfaceAt(underlineX, underlineY, sauge) ? "var(--beige)" : "var(--orange)";

        text.style.setProperty("--nav-tone-gradient", buildTextGradient(text, sauge));
        text.style.setProperty("--nav-underline-color", underlineColor);
      });
    };

    let frame = 0;

    const requestUpdate = () => {
      if (frame) return;
      frame = window.requestAnimationFrame(() => {
        frame = 0;
        updateLinkTone();
      });
    };

    updateLinkTone();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    window.addEventListener("pageshow", requestUpdate);
    window.addEventListener("cj:page-transition-revealed", requestUpdate);
  })();
</script>

<style>
  .site-header {
    position: fixed;
    /* La nav partage la MÊME ligne haute de composition que les
       gros titres de page (hero home, /work, pages projet). Côté
       titres, cette ligne correspond au top de la box du h1, soit
       --page-top-line + --title-top-offset. Côté nav, on place le
       top de la box du header sur exactement la même valeur via
       --nav-top-offset (= --title-top-offset). Le haut visible du
       "A" de "ABOUT" et le haut visible du "C" de "Clément" / "W"
       de "Works" / etc. tombent alors sur la même ligne, à tout
       viewport, via le clamp de --type-display. */
    top: calc(var(--page-top-line) + var(--nav-top-offset));
    right: var(--pad-x);
    z-index: 100;
  }

  nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.28rem;
    margin: 0;
    padding: 0;
  }

  nav a {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    color: var(--orange);
    margin: 0;
    padding: 0.08rem 0 0.08rem 0.7rem;
    display: block;
  }

  .site-header [data-scramble-text] {
    background-image: var(--nav-tone-gradient, linear-gradient(var(--orange), var(--orange)));
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .site-header [data-scramble-text]::after {
    background: var(--nav-underline-color, var(--orange));
  }

  /* Aucune variation d'opacité ici : l'interaction se fait via
     l'underline de .interactive-text (hover) et la règle
     .interactive-text.active (underline permanent sur la page courante).
     Le lien actif reste à pleine opacité, juste souligné. */
</style>
