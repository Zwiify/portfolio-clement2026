---
---

<footer id="contact" class="contact">
  <div class="contact-top">
    <p class="contact-label">Contact</p>
    <p class="contact-sub">
      &mdash;&nbsp;disponible pour stages et projets
    </p>
  </div>

  <!-- ligne pointillée horizontale qui traverse le vide à mi-hauteur -->
  <div class="contact-rule" aria-hidden="true"></div>

  <div class="contact-bottom">
    <div class="contact-lines">
      <a
        href="mailto:clement@jorge.fr"
        class="contact-line interactive-zone"
      >
        <span data-scramble-text="">clement@jorge.fr</span>
      </a>
      <a
        href="tel:+33699550367"
        class="contact-line interactive-zone"
      >
        <span data-scramble-text="">+06 99 55 03 67</span>
      </a>
    </div>

    <div class="contact-meta">
      <div class="contact-social">
        <a
          href="https://www.linkedin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="interactive-zone"
        >
          <span data-scramble-text="">LinkedIn</span>
        </a>
        <a
          href="https://www.instagram.com"
          target="_blank"
          rel="noopener noreferrer"
          class="interactive-zone"
        >
          <span data-scramble-text="">Instagram</span>
        </a>
      </div>
      <p class="contact-copy">© 2026 &mdash; Clément Jorge</p>
    </div>
  </div>
</footer>

<style>
  .contact {
    background: var(--beige);
    color: var(--noir);
    padding: 2rem var(--pad-x) 1.5rem;
    min-height: 46vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  /* top : label + sous-titre en ligne */
  .contact-top {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .contact-label {
    font-family: var(--font-body);
    font-size: var(--type-body);
    font-weight: 400;
    margin: 0;
  }

  .contact-sub {
    font-family: var(--font-body);
    font-size: var(--type-body);
    margin: 0;
    opacity: 0.55;
  }

  /* ligne pointillée qui tient le vide */
  .contact-rule {
    align-self: stretch;
    height: 1px;
    background-image: repeating-linear-gradient(
      to right,
      var(--noir) 0 4px,
      transparent 4px 9px
    );
    opacity: 0.3;
  }

  /* bas : email + téléphone, social + copyright */
  .contact-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .contact-lines {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .contact-line {
    font-family: var(--font-display);
    font-size: var(--type-contact);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    transition: color 0.15s ease;
  }

  .contact-line:hover {
    color: var(--orange);
  }

  .contact-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    margin-top: 0.5rem;
  }

  .contact-social {
    display: flex;
    gap: 4.5rem;
    font-family: var(--font-body);
    font-size: var(--type-body);
  }

  .contact-social a {
    transition: color 0.15s ease;
  }

  .contact-social a:hover {
    color: var(--orange);
  }

  .contact-copy {
    font-family: var(--font-body);
    font-size: 11px;
    opacity: 0.5;
    margin: 0;
    letter-spacing: 0.02em;
  }

  @media (max-width: 960px) {
    .contact-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
