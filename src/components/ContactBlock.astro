<footer id="contact" class="contact">
  <div class="contact-top">
    <p class="contact-label">Contact</p>
    <p class="contact-sub">
      &mdash;&nbsp;disponible pour stages et projets
    </p>
  </div>

  <div class="contact-bottom">
    <div class="contact-lines">
      <a href="mailto:clemen@jorge.fr" class="contact-line">clemen@jorge.fr</a>
      <a href="tel:+33699550367" class="contact-line">+06 99 55 03 67</a>
    </div>

    <div class="contact-meta">
      <div class="contact-social">
        <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer">Instagram</a>
      </div>
      <p class="contact-copy">© 2026 &mdash; Clément Jorge</p>
    </div>
  </div>
</footer>

<style>
  .contact {
    background: var(--beige);
    color: var(--noir);
    padding: 2rem var(--pad-x) 1.5rem;
    min-height: 46vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .contact-top {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .contact-label {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 400;
    margin: 0;
  }

  .contact-sub {
    font-family: var(--font-body);
    font-size: 13px;
    margin: 0;
    opacity: 0.6;
  }

  .contact-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .contact-lines {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .contact-line {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 2.8vw, 2.85rem);
    font-weight: 700;
    letter-spacing: -0.028em;
    line-height: 1;
    transition: color 0.15s ease;
  }

  .contact-line:hover {
    color: var(--orange);
  }

  .contact-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    margin-top: 0.4rem;
  }

  .contact-social {
    display: flex;
    gap: 4.5rem;
    font-size: 13px;
  }

  .contact-social a {
    transition: color 0.15s ease;
  }

  .contact-social a:hover {
    color: var(--orange);
  }

  .contact-copy {
    font-family: var(--font-body);
    font-size: 11.5px;
    opacity: 0.55;
    margin: 0;
    letter-spacing: 0.015em;
  }

  @media (max-width: 960px) {
    .contact-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }
</style>
