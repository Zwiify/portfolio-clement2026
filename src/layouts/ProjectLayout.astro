---
/**
 * ProjectLayout
 * ------------------------------------------------------------
 * Layout réutilisable pour toutes les pages de projet (/work/*).
 *
 * Objectifs :
 * - Garantir la cohérence DA entre toutes les pages projet
 *   (même alignement haut que /work et la homepage, même
 *   système typographique, même fond, même rythme).
 * - Centraliser la structure (titre, méta, hero image, blocs
 *   de projets et galeries) pour que chaque nouvelle matière soit une simple
 *   fiche de données, pas un travail de CSS.
 *
 * Pilotage d'une page projet : on passe les données en frontmatter
 * (title, year, category, hero, projectSections) et la page affiche
 * automatiquement la mise en page éditoriale.
 *
 * Pour des cas plus libres, un <slot /> "extra" est laissé en fin
 * de layout (avant le footer) pour ajouter du contenu spécifique
 * sans casser le template.
 * ------------------------------------------------------------
 */
import BaseLayout from "./BaseLayout.astro";
import MediaBlock from "../components/MediaBlock.astro";
import { workIndex } from "../data/work";
import type { GalleryItem, ImageAsset, PlaceholderTone, ProjectSection } from "../data/types";

export interface Props {
  /** Titre du projet — affiché en gros à la place de "Works". */
  title: string;
  /** Année(s) du projet, affiché en petit à droite du titre. */
  year?: string;
  /** Catégorie éditoriale (ex : "identité", "édition"). */
  category?: string;
  /** Intro du projet : une ou plusieurs paragraphes. */
  intro?: string | string[];
  /** Légende sous l'image principale. */
  heroCaption?: string;
  /** Image principale. Laisse `src` vide pour conserver le placeholder bleu. */
  heroImage?: ImageAsset;
  /** Ratio indicatif de l'image principale. Sa hauteur est plafonnée côté CSS. */
  heroRatio?: string;
  /** Ton du placeholder principal. Défaut : bleu. */
  heroTone?: PlaceholderTone;
  /** Galerie d'images du projet. */
  gallery?: GalleryItem[];
  /** Blocs de projets à afficher après l'image d'arrivée. */
  projectSections?: ProjectSection[];
  /** Titre HTML de l'onglet. Défaut : "<title> — Clément Jorge". */
  pageTitle?: string;
  /** Meta description SEO. */
  description?: string;
}

const {
  title,
  year,
  category,
  intro,
  heroCaption,
  heroImage,
  heroRatio = "21 / 9",
  heroTone = "bleu",
  gallery = [],
  projectSections = [],
  pageTitle,
  description,
} = Astro.props;

const introParagraphs = Array.isArray(intro) ? intro : intro ? [intro] : [];
const contentSections =
  projectSections.length > 0
    ? projectSections
    : introParagraphs.length > 0 || gallery.length > 0
      ? [{ title: "Projet", description: introParagraphs, images: gallery }]
      : [];

const finalPageTitle = pageTitle ?? `${title} — Clément Jorge`;
const currentWorkIndex = workIndex.findIndex((item) => item.title === title);
const nextWork =
  currentWorkIndex >= 0
    ? workIndex[(currentWorkIndex + 1) % workIndex.length]
    : undefined;

const lightboxGroups = contentSections.map((section) => ({
  title: section.title,
  images: (section.images ?? [])
    .filter((item) => item.src)
    .map((item) => ({
      src: item.src,
      alt: item.alt ?? item.caption ?? section.title,
      caption: item.caption ?? "",
    })),
}));
---

<BaseLayout title={finalPageTitle} description={description}>
  <article class="project">
    <!-- ============================================================
         HEADER — titre aligné sur la ligne haute partagée avec la nav
         (même système que /work et le hero home).
         ============================================================ -->
    <header class="project-header">
      <h1 class="project-title">{title}</h1>

      {(year || category) && (
        <div class="project-meta">
          {category && <p class="project-category">{category}</p>}
          {year && <p class="project-year">{year}</p>}
        </div>
      )}
    </header>

    <!-- ============================================================
         HERO IMAGE — image dominante, largeur 100 % de la colonne
         ============================================================ -->
    <figure class={`project-hero tone-${heroTone}`}>
      <div class="project-hero-media" style={`aspect-ratio: ${heroRatio};`}>
        <MediaBlock src={heroImage?.src} alt={heroImage?.alt ?? title} loading="eager" />
      </div>
      {heroCaption && <figcaption>{heroCaption}</figcaption>}
    </figure>

    <!-- ============================================================
         PROJECT SECTIONS — titre à gauche, texte à droite, images par paire
         ============================================================ -->
    {contentSections.length > 0 && (
      <div class="project-sections">
        {contentSections.map((section, sectionIndex) => {
          const paragraphs = Array.isArray(section.description)
            ? section.description
            : section.description
              ? [section.description]
              : [];
          let lightboxImageIndex = -1;

          return (
            <section class="project-section">
              <div class="project-section-copy">
                <h2>{section.title}</h2>
                <div class="project-section-text">
                  {paragraphs.map((p) => <p>{p}</p>)}
                </div>
              </div>

              {(section.images?.length ?? 0) > 0 && (
                <div class="project-section-gallery" aria-label={`Images - ${section.title}`}>
                  {section.images?.map((item) => {
                    const itemLightboxIndex = item.src ? ++lightboxImageIndex : -1;

                    return (
                      <figure class={`gallery-item gallery-item--${item.span ?? "half"} tone-${item.tone ?? "bleu"}`}>
                        {item.src ? (
                          <button
                            class="gallery-lightbox-trigger interactive-zone"
                            type="button"
                            data-gallery-group={sectionIndex}
                            data-gallery-index={itemLightboxIndex}
                            aria-label={`Agrandir ${item.alt ?? item.caption ?? section.title}`}
                          >
                            <span
                              class="gallery-media"
                              style={`aspect-ratio: ${item.ratio ?? (item.span === "full" ? "16 / 9" : "3 / 2")};`}
                            >
                              <MediaBlock src={item.src} alt={item.alt ?? item.caption ?? ""} />
                            </span>
                          </button>
                        ) : (
                          <div
                            class="gallery-media"
                            style={`aspect-ratio: ${item.ratio ?? (item.span === "full" ? "16 / 9" : "3 / 2")};`}
                          >
                            <MediaBlock src={item.src} alt={item.alt ?? item.caption ?? ""} />
                          </div>
                        )}
                        {item.caption && <figcaption>{item.caption}</figcaption>}
                      </figure>
                    );
                  })}
                </div>
              )}
            </section>
          );
        })}
      </div>
    )}

    <!-- Slot libre pour du contenu spécifique à une page projet
         (texte long, citation, vidéo embarquée…) sans modifier le layout. -->
    <slot name="extra" />

    {nextWork && (
      <nav class="next-project" aria-label="Navigation entre les pages work">
        <a
          href={`/work/${nextWork.slug}`}
          class="next-project-link interactive-zone"
          aria-label={`Projet suivant : ${nextWork.title}`}
        >
          <span data-scramble-text="">Projet suivant ↗</span>
        </a>
      </nav>
    )}
  </article>

  <div class="project-lightbox" data-project-lightbox aria-hidden="true">
    <button class="project-lightbox-close interactive-zone" type="button" data-lightbox-close aria-label="Fermer l'image agrandie">
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>

    <button class="project-lightbox-arrow project-lightbox-arrow--prev interactive-zone" type="button" data-lightbox-prev aria-label="Image précédente">
      ‹
    </button>

    <figure class="project-lightbox-figure">
      <img class="project-lightbox-image" data-lightbox-image src="" alt="" decoding="async" />
      <figcaption class="project-lightbox-caption" data-lightbox-caption></figcaption>
    </figure>

    <button class="project-lightbox-arrow project-lightbox-arrow--next interactive-zone" type="button" data-lightbox-next aria-label="Image suivante">
      ›
    </button>

    <p class="project-lightbox-counter" data-lightbox-counter aria-live="polite"></p>
  </div>

  <script type="application/json" id="project-lightbox-data" set:html={JSON.stringify(lightboxGroups)} />
</BaseLayout>

<script>
  (() => {
    const project = document.querySelector(".project");
    const header = document.querySelector(".project-header");
    const hero = document.querySelector(".project-hero");

    if (!project || !header || !hero) return;

    const updateTitleVisibility = () => {
      const headerRect = header.getBoundingClientRect();
      const heroRect = hero.getBoundingClientRect();
      project.classList.toggle("project-title-is-hidden", heroRect.bottom <= headerRect.bottom);
    };

    let frame = 0;

    const requestUpdate = () => {
      if (frame) return;
      frame = window.requestAnimationFrame(() => {
        frame = 0;
        updateTitleVisibility();
      });
    };

    updateTitleVisibility();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
    window.addEventListener("pageshow", requestUpdate);
    window.addEventListener("cj:page-transition-revealed", requestUpdate);
  })();

  (() => {
    const dataEl = document.getElementById("project-lightbox-data");
    const overlay = document.querySelector("[data-project-lightbox]");
    const image = document.querySelector("[data-lightbox-image]");
    const caption = document.querySelector("[data-lightbox-caption]");
    const counter = document.querySelector("[data-lightbox-counter]");
    const closeButton = document.querySelector("[data-lightbox-close]");
    const prevButton = document.querySelector("[data-lightbox-prev]");
    const nextButton = document.querySelector("[data-lightbox-next]");

    if (!dataEl || !overlay || !image || !caption || !counter || !closeButton || !prevButton || !nextButton) return;

    let groups = [];
    try {
      groups = JSON.parse(dataEl.textContent || "[]");
    } catch {
      groups = [];
    }

    let currentGroup = 0;
    let currentIndex = 0;
    let lastFocused = null;

    const getCurrentImages = () => groups[currentGroup]?.images ?? [];

    const showImage = (index) => {
      const images = getCurrentImages();
      if (!images.length) return;

      currentIndex = (index + images.length) % images.length;
      const item = images[currentIndex];

      image.src = item.src;
      image.alt = item.alt || "";
      caption.textContent = item.caption || "";
      caption.hidden = !item.caption;
      prevButton.hidden = images.length < 2;
      nextButton.hidden = images.length < 2;
      counter.hidden = images.length < 2;
      counter.textContent = `${currentIndex + 1}/${images.length}`;
    };

    const openLightbox = (groupIndex, imageIndex, trigger) => {
      currentGroup = groupIndex;
      currentIndex = imageIndex;
      lastFocused = trigger;
      showImage(currentIndex);
      overlay.setAttribute("aria-hidden", "false");
      document.documentElement.classList.add("project-lightbox-open");
      closeButton.focus({ preventScroll: true });
    };

    const closeLightbox = () => {
      overlay.setAttribute("aria-hidden", "true");
      document.documentElement.classList.remove("project-lightbox-open");
      image.removeAttribute("src");
      if (lastFocused instanceof HTMLElement) {
        lastFocused.focus({ preventScroll: true });
      }
    };

    document.querySelectorAll("[data-gallery-group][data-gallery-index]").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const groupIndex = Number(trigger.getAttribute("data-gallery-group"));
        const imageIndex = Number(trigger.getAttribute("data-gallery-index"));
        openLightbox(groupIndex, imageIndex, trigger);
      });
    });

    closeButton.addEventListener("click", closeLightbox);
    prevButton.addEventListener("click", () => showImage(currentIndex - 1));
    nextButton.addEventListener("click", () => showImage(currentIndex + 1));

    overlay.addEventListener("click", (event) => {
      if (event.target === overlay) closeLightbox();
    });

    window.addEventListener("keydown", (event) => {
      if (overlay.getAttribute("aria-hidden") === "true") return;

      if (event.key === "Escape") closeLightbox();
      if (event.key === "ArrowLeft") showImage(currentIndex - 1);
      if (event.key === "ArrowRight") showImage(currentIndex + 1);
    });
  })();
</script>

<style>
  /* ==========================================================
     CONTAINER — même fond que /work pour la continuité visuelle
     quand on clique sur un projet depuis la liste.
     ========================================================== */
  .project {
    background: var(--sauge);
    color: var(--noir);
    --project-rhythm: clamp(6rem, 10vw, 11rem);
    /* Ligne haute partagée avec la nav : --page-top + compensation
       du line-height 0.76 du titre display. */
    padding: calc(var(--page-top) + var(--title-top-offset)) var(--pad-x) 2rem;
    min-height: 100vh;
    isolation: isolate;
  }

  /* ==========================================================
     HEADER — titre à gauche, méta (catégorie / année) à droite
     aligné baseline basse comme sur /work
     ========================================================== */
  .project-header {
    position: sticky;
    top: calc(var(--page-top) + var(--title-top-offset));
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 3rem;
    margin: 0 0 clamp(10rem, 22vh, 18rem);
    padding-right: 6rem; /* réserve la place du header nav fixé */
    transition: opacity 0.16s ease;
  }

  .project-title-is-hidden .project-header {
    opacity: 0;
    pointer-events: none;
  }

  /* Même typo que le hero home et le titre /work */
  .project-title {
    font-family: var(--font-display);
    font-size: var(--type-display);
    font-weight: 600;
    letter-spacing: var(--tracking-hero);
    line-height: 0.88;
    margin: 0;
    max-width: 14ch;
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    text-align: right;
    flex-shrink: 0;
  }

  .project-category {
    font-family: var(--font-body);
    font-size: var(--type-body);
    font-weight: 400;
    text-transform: lowercase;
    letter-spacing: 0.015em;
    margin: 0;
    opacity: 0.9;
  }

  .project-year {
    font-family: var(--font-body);
    font-size: var(--type-body);
    font-weight: 400;
    letter-spacing: 0.02em;
    margin: 0;
    opacity: 0.6;
  }

  /* ==========================================================
     HERO image — bloc d'ouverture volontairement plus haut que
     le viewport : l'image dépasse en bas et appelle au scroll.
     ========================================================== */
  .project-hero {
    position: relative;
    z-index: 2;
    margin: 0 0 var(--project-rhythm);
  }

  .project-hero-media {
    width: 100%;
    height: clamp(38rem, 88vh, 62rem);
    background: var(--bleu);
    overflow: hidden;
  }

  .project-hero figcaption {
    font-family: var(--font-body);
    font-size: var(--type-caption);
    letter-spacing: 0.01em;
    opacity: 0.6;
    margin-top: 0.7rem;
  }

  /* ==========================================================
     PROJECT SECTIONS — système répétable :
     nom du projet à gauche, texte à droite, images par paire.
     ========================================================== */
  .project-sections {
    position: relative;
    z-index: 3;
    display: grid;
    gap: var(--project-rhythm);
    background: var(--sauge);
  }

  .project-sections::before {
    content: "";
    position: absolute;
    inset: calc(var(--project-rhythm) * -1) 0 100%;
    background: var(--sauge);
    pointer-events: none;
  }

  .project-section {
    display: grid;
    gap: clamp(2.5rem, 5vw, 5rem);
  }

  .project-section-copy {
    display: grid;
    grid-template-columns: minmax(10rem, 0.9fr) minmax(24rem, 1fr);
    column-gap: clamp(2rem, 6vw, 7rem);
    align-items: start;
    min-height: clamp(14rem, 28vh, 22rem);
  }

  .project-section h2 {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.15vw, 1.35rem);
    line-height: 1.35;
    letter-spacing: 0.02em;
    margin: 0;
    font-weight: 600;
  }

  .project-section-text {
    display: grid;
    gap: 1rem;
    max-width: 58ch;
  }

  .project-section-text p {
    font-family: var(--font-body);
    font-size: clamp(1.35rem, 1.65vw, 2rem);
    line-height: 1.32;
    letter-spacing: -0.035em;
    margin: 0;
  }

  /* ==========================================================
     GALLERY — grille stricte par paires, items uniformes
     ========================================================== */
  .project-section-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 1.3rem;
    row-gap: 1.3rem;
  }

  .gallery-item {
    margin: 0;
    min-width: 0;
  }

  /* gardé pour compat : si une page a besoin d'un item pleine largeur */
  .gallery-item--full {
    grid-column: 1 / -1;
  }

  .gallery-media {
    display: block;
    width: 100%;
    background: var(--beige);
    overflow: hidden;
  }

  .gallery-media :global(.media-block-image) {
    object-fit: contain;
  }

  .gallery-lightbox-trigger {
    display: block;
    width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    text-align: inherit;
  }

  .gallery-lightbox-trigger :global(.media-block-image) {
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), filter 0.45s ease;
  }

  .gallery-lightbox-trigger:hover :global(.media-block-image),
  .gallery-lightbox-trigger:focus-visible :global(.media-block-image) {
    transform: scale(1.025);
    filter: contrast(1.02);
  }

  .gallery-lightbox-trigger:focus-visible {
    outline: 2px solid var(--orange);
    outline-offset: 0.25rem;
  }

  .gallery-item figcaption {
    font-family: var(--font-body);
    font-size: var(--type-caption);
    letter-spacing: 0.01em;
    opacity: 0.55;
    margin-top: 0.65rem;
  }

  /* ==========================================================
     TONALITÉS de placeholder : permettent de varier les blocs
     sans modifier le CSS, via la prop `tone`.
     ========================================================== */
  .tone-bleu   .project-hero-media,
  .tone-bleu   .gallery-media   { background: var(--bleu); }
  .tone-sauge  .project-hero-media,
  .tone-sauge  .gallery-media   { background: var(--sauge); }
  .tone-beige  .project-hero-media,
  .tone-beige  .gallery-media   { background: var(--beige); }
  .tone-orange .project-hero-media,
  .tone-orange .gallery-media   { background: var(--orange); }
  .tone-noir   .project-hero-media,
  .tone-noir   .gallery-media   { background: var(--noir); }

  .project-section-gallery .gallery-media {
    background: var(--beige);
  }

  /* ==========================================================
     NEXT PROJECT — navigation rapide entre les matières,
     dans l'ordre de la page /work.
     ========================================================== */
  .next-project {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 1.3rem;
    margin-top: var(--project-rhythm);
    background: var(--sauge);
  }

  .next-project-link {
    position: relative;
    z-index: 1;
    grid-column: 2;
    justify-self: end;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.75vw, 3.45rem);
    font-weight: 500;
    line-height: 1.06;
    letter-spacing: var(--tracking-tight);
    color: var(--noir);
  }

  .next-project::before {
    content: "";
    position: absolute;
    inset: calc(var(--project-rhythm) * -1) 0 0;
    background: var(--sauge);
    pointer-events: none;
  }

  /* ==========================================================
     LIGHTBOX — consultation grand format des images de projet.
     Chaque galerie navigue uniquement dans sa section/projet.
     ========================================================== */
  :global(html.project-lightbox-open),
  :global(html.project-lightbox-open body) {
    overflow: hidden;
  }

  .project-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: grid;
    place-items: center;
    padding: clamp(4rem, 7vw, 7rem) clamp(4rem, 8vw, 8rem);
    isolation: isolate;
    background: transparent;
    opacity: 0;
    pointer-events: none;
    transition: none;
  }

  .project-lightbox::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgba(12, 14, 13, 0.82);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    transform: translateZ(0);
    will-change: backdrop-filter;
  }

  .project-lightbox[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .project-lightbox-figure {
    display: grid;
    place-items: center;
    margin: 0;
    max-width: min(82vw, 92rem);
    max-height: min(78vh, 58rem);
    opacity: 0;
    transform: translateY(0.4rem);
    transition: opacity 0.18s ease, transform 0.18s ease;
  }

  .project-lightbox[aria-hidden="false"] .project-lightbox-figure {
    opacity: 1;
    transform: translateY(0);
  }

  .project-lightbox-image {
    display: block;
    width: auto;
    height: auto;
    max-width: min(82vw, 92rem);
    max-height: min(78vh, 58rem);
    background: transparent;
    object-fit: contain;
    box-shadow: 0 1.8rem 7rem rgba(0, 0, 0, 0.35);
  }

  .project-lightbox-caption {
    justify-self: start;
    max-width: 72ch;
    margin-top: 0.9rem;
    color: var(--beige);
    font-family: var(--font-body);
    font-size: var(--type-caption);
    opacity: 0.78;
  }

  .project-lightbox-close,
  .project-lightbox-arrow {
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--beige);
    cursor: pointer;
  }

  .project-lightbox-close {
    position: fixed;
    top: clamp(1.6rem, 3vw, 3rem);
    right: clamp(1.6rem, 3vw, 3rem);
    width: 3.4rem;
    height: 3.4rem;
  }

  .project-lightbox-close span {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 2.7rem;
    height: 0.14rem;
    background: currentColor;
    transform-origin: center;
  }

  .project-lightbox-close span:first-child {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .project-lightbox-close span:last-child {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .project-lightbox-arrow {
    position: fixed;
    top: 50%;
    width: 4rem;
    height: 4rem;
    transform: translateY(-50%);
    font-family: var(--font-body);
    font-size: clamp(3.4rem, 4vw, 5rem);
    font-weight: 300;
    line-height: 0.75;
  }

  .project-lightbox-arrow--prev {
    left: clamp(1.4rem, 3.2vw, 4rem);
  }

  .project-lightbox-arrow--next {
    right: clamp(1.4rem, 3.2vw, 4rem);
  }

  .project-lightbox-counter {
    position: fixed;
    left: 50%;
    bottom: clamp(1.55rem, 3vw, 3rem);
    transform: translateX(-50%);
    margin: 0;
    color: var(--beige);
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1vw, 1.15rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }

  .project-lightbox-close:hover,
  .project-lightbox-arrow:hover {
    opacity: 0.72;
  }

  .project-lightbox-close:focus-visible,
  .project-lightbox-arrow:focus-visible {
    outline: 2px solid var(--beige);
    outline-offset: 0.35rem;
  }

  /* ==========================================================
     RESPONSIVE
     ========================================================== */
  @media (max-width: 960px) {
    .project-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 3rem;
      padding-right: 0;
    }
    .project-meta {
      align-items: flex-start;
