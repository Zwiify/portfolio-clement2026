---
/**
 * ProjectLayout
 * ------------------------------------------------------------
 * Layout réutilisable pour toutes les pages de projet (/work/*).
 *
 * Objectifs :
 * - Garantir la cohérence DA entre toutes les pages projet
 *   (même alignement haut que /work et la homepage, même
 *   système typographique, même fond, même rythme).
 * - Centraliser la structure (titre, méta, hero image, intro,
 *   galerie) pour que chaque nouvelle matière soit une simple
 *   fiche de données, pas un travail de CSS.
 *
 * Pilotage d'une page projet : on passe les données en frontmatter
 * (title, year, category, intro, hero, gallery) et la page affiche
 * automatiquement la mise en page éditoriale.
 *
 * Pour des cas plus libres, un <slot /> "extra" est laissé en fin
 * de layout (avant le footer) pour ajouter du contenu spécifique
 * sans casser le template.
 * ------------------------------------------------------------
 */
import BaseLayout from "./BaseLayout.astro";

export interface GalleryItem {
  /** Légende optionnelle sous le bloc image. */
  caption?: string;
  /**
   * Largeur du bloc dans la grille 2 colonnes.
   * - "half"  : 1 colonne (défaut)
   * - "full"  : pleine largeur (2 colonnes)
   */
  span?: "half" | "full";
  /**
   * Ratio d'aspect du bloc image.
   * Par défaut : 4/5 pour les half, 16/9 pour les full.
   */
  ratio?: string;
  /** Couleur de fond du placeholder (var CSS). Défaut : --bleu. */
  tone?: "bleu" | "sauge" | "beige" | "orange" | "noir";
}

export interface Props {
  /** Titre du projet — affiché en gros à la place de "Works". */
  title: string;
  /** Année(s) du projet, affiché en petit à droite du titre. */
  year?: string;
  /** Catégorie éditoriale (ex : "identité", "édition"). */
  category?: string;
  /** Intro du projet : une ou plusieurs paragraphes. */
  intro?: string | string[];
  /** Légende sous l'image principale. */
  heroCaption?: string;
  /** Ratio de l'image principale. Défaut : 16/9. */
  heroRatio?: string;
  /** Ton du placeholder principal. Défaut : bleu. */
  heroTone?: "bleu" | "sauge" | "beige" | "orange" | "noir";
  /** Galerie d'images du projet. */
  gallery?: GalleryItem[];
  /** Titre HTML de l'onglet. Défaut : "<title> — Clément Jorge". */
  pageTitle?: string;
  /** Meta description SEO. */
  description?: string;
}

const {
  title,
  year,
  category,
  intro,
  heroCaption,
  heroRatio = "16 / 9",
  heroTone = "bleu",
  gallery = [],
  pageTitle,
  description,
} = Astro.props;

const introParagraphs = Array.isArray(intro) ? intro : intro ? [intro] : [];

const finalPageTitle = pageTitle ?? `${title} — Clément Jorge`;
---

<BaseLayout title={finalPageTitle} description={description}>
  <article class="project">
    <!-- ============================================================
         HEADER — titre aligné sur la ligne haute partagée avec la nav
         (même système que /work et le hero home).
         ============================================================ -->
    <header class="project-header">
      <h1 class="project-title">{title}</h1>

      {(year || category) && (
        <div class="project-meta">
          {category && <p class="project-category">{category}</p>}
          {year && <p class="project-year">{year}</p>}
        </div>
      )}
    </header>

    <!-- ============================================================
         HERO IMAGE — image dominante, largeur 100 % de la colonne
         ============================================================ -->
    <figure class={`project-hero tone-${heroTone}`}>
      <div class="project-hero-media" style={`aspect-ratio: ${heroRatio};`}></div>
      {heroCaption && <figcaption>{heroCaption}</figcaption>}
    </figure>

    <!-- ============================================================
         INTRO — texte éditorial resserré, deux paragraphes max
         ============================================================ -->
    {introParagraphs.length > 0 && (
      <section class="project-intro">
        {introParagraphs.map((p) => <p>{p}</p>)}
      </section>
    )}

    <!-- ============================================================
         GALLERY — grille 2 colonnes, items "half" ou "full"
         ============================================================ -->
    {gallery.length > 0 && (
      <section class="project-gallery" aria-label="Galerie">
        {gallery.map((item) => (
          <figure class={`gallery-item gallery-item--${item.span ?? "half"} tone-${item.tone ?? "bleu"}`}>
            <div
              class="gallery-media"
              style={`aspect-ratio: ${item.ratio ?? (item.span === "full" ? "16 / 9" : "4 / 5")};`}
            ></div>
            {item.caption && <figcaption>{item.caption}</figcaption>}
          </figure>
        ))}
      </section>
    )}

    <!-- Slot libre pour du contenu spécifique à une page projet
         (texte long, citation, vidéo embarquée…) sans modifier le layout. -->
    <slot name="extra" />
  </article>
</BaseLayout>

<style>
  /* ==========================================================
     CONTAINER — même fond que /work pour la continuité visuelle
     quand on clique sur un projet depuis la liste.
     ========================================================== */
  .project {
    background: var(--sauge);
    color: var(--noir);
    /* Ligne haute partagée avec la nav : --page-top + compensation
       du line-height 0.76 du titre display. */
    padding: calc(var(--page-top) + var(--title-top-offset)) var(--pad-x) 7rem;
    min-height: 100vh;
  }

  /* ==========================================================
     HEADER — titre à gauche, méta (catégorie / année) à droite
     aligné baseline basse comme sur /work
     ========================================================== */
  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 3rem;
    margin: 0 0 4.5rem;
    padding-right: 6rem; /* réserve la place du header nav fixé */
  }

  /* Même typo que le hero home et le titre /work */
  .project-title {
    font-family: var(--font-display);
    font-size: var(--type-display);
    font-weight: 600;
    letter-spacing: var(--tracking-hero);
    line-height: 0.76;
    margin: 0;
    max-width: 14ch;
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    text-align: right;
    flex-shrink: 0;
  }

  .project-category {
    font-family: var(--font-body);
    font-size: var(--type-body);
    font-weight: 400;
    text-transform: lowercase;
    letter-spacing: 0.015em;
    margin: 0;
    opacity: 0.9;
  }

  .project-year {
    font-family: var(--font-body);
    font-size: var(--type-body);
    font-weight: 400;
    letter-spacing: 0.02em;
    margin: 0;
    opacity: 0.6;
  }

  /* ==========================================================
     HERO image — bloc dominant, presque pleine largeur utile,
     avec respiration autour (cf. chemin de fer)
     ========================================================== */
  .project-hero {
    margin: 0 0 3.5rem;
  }

  .project-hero-media {
    width: 100%;
    background: var(--bleu);
  }

  .project-hero figcaption {
    font-family: var(--font-body);
    font-size: var(--type-caption);
    letter-spacing: 0.01em;
    opacity: 0.6;
    margin-top: 0.7rem;
  }

  /* ==========================================================
     INTRO — paragraphes empilés à gauche, largeur sobre
     (cf. chemin de fer : 2 blocs de texte sous la grande image)
     ========================================================== */
  .project-intro {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    max-width: 60ch;
    margin: 0 0 6rem 0;
  }

  .project-intro p {
    font-family: var(--font-body);
    font-size: 13.25px;
    line-height: 1.6;
    margin: 0;
  }

  /* ==========================================================
     GALLERY — grille stricte 2 × 2, items uniformes
     ========================================================== */
  .project-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: 1.3rem;
    row-gap: 1.3rem;
  }

  .gallery-item {
    margin: 0;
    min-width: 0;
  }

  /* gardé pour compat : si une page a besoin d'un item pleine largeur */
  .gallery-item--full {
    grid-column: 1 / -1;
  }

  .gallery-media {
    width: 100%;
    background: var(--bleu);
  }

  .gallery-item figcaption {
    font-family: var(--font-body);
    font-size: var(--type-caption);
    letter-spacing: 0.01em;
    opacity: 0.55;
    margin-top: 0.65rem;
  }

  /* ==========================================================
     TONALITÉS de placeholder : permettent de varier les blocs
     sans modifier le CSS, via la prop `tone`.
     ========================================================== */
  .tone-bleu   .project-hero-media,
  .tone-bleu   .gallery-media   { background: var(--bleu); }
  .tone-sauge  .project-hero-media,
  .tone-sauge  .gallery-media   { background: var(--sauge); }
  .tone-beige  .project-hero-media,
  .tone-beige  .gallery-media   { background: var(--beige); }
  .tone-orange .project-hero-media,
  .tone-orange .gallery-media   { background: var(--orange); }
  .tone-noir   .project-hero-media,
  .tone-noir   .gallery-media   { background: var(--noir); }

  /* ==========================================================
     RESPONSIVE
     ========================================================== */
  @media (max-width: 960px) {
    .project-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 3rem;
      padding-right: 0;
    }
    .project-meta {
      align-items: flex-start;
      text-align: left;
      flex-direction: row;
      gap: 1rem;
    }
    .project-intro {
      grid-template-columns: 1fr;
      margin-left: 0;
      margin-bottom: 4rem;
    }
    .project-gallery {
      grid-template-columns: 1fr;
      row-gap: 2rem;
    }
  }
</style>
