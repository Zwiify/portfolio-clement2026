---
import "../styles/global.css";
import Header from "../components/Header.astro";
import ContactBlock from "../components/ContactBlock.astro";
import CursorDot from "../components/CursorDot.astro";
import PageTransition from "../components/PageTransition.astro";
import TextHoverEffects from "../components/TextHoverEffects.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Clément Jorge — design graphique",
  description = "Portfolio de Clément Jorge, étudiant en design graphique.",
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      try {
        if (sessionStorage.getItem("cj-page-transition") === "1") {
          document.documentElement.classList.add("has-page-transition-enter");
        }
      } catch (_) {
        /* no-op */
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <ContactBlock />
    <CursorDot />
    <PageTransition />
    <TextHoverEffects />
  </body>
</html>
